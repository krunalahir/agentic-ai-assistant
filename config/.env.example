# Agentic AI Assistant - Environment Variables
# Copy this file to .env and fill in your actual API keys

# Mistral AI API Key
# Get your key from: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=your_mistral_api_key_here

# Alpha Vantage API Key (for stock prices)
# Get your free key from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Optional: RAG Vector Store Path (default is data/vector_store)
# RAG_VECTOR_STORE_PATH=data/vector_store
